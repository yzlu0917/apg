{
  "phase": "object_gate",
  "status": "bootstrapped",
  "date_frozen": "2026-03-31",
  "environment": {
    "conda_env": "infer",
    "default_model_family": "Qwen3",
    "default_model_tier": "1.7B",
    "fallback_model_tier": "4B",
    "api_generation_enabled": false
  },
  "task_source": {
    "primary": "Reasoning Gym",
    "primary_status": "installed",
    "external_enabled": false,
    "family_names_frozen": true,
    "freeze_rule": "Freeze exactly 2 high-dependency families and 2 shallow families before any data generation beyond the tiny pilot.",
    "families": {
      "high_dependency": [
        "tower_of_hanoi",
        "countdown"
      ],
      "shallow": [
        "basic_arithmetic",
        "gcd"
      ]
    }
  },
  "prompt_protocol": {
    "version": "v2_prefill_reasoning",
    "trace_mode": "explicit_reasoning",
    "wrapper_policy": "programmatic_task_instance_plus_thin_model_wrapper_with_assistant_prefill",
    "reasoning_format": {
      "tag": "reasoning",
      "step_unit": "one_short_step_per_line",
      "target_step_count": "3_to_8",
      "must_not_duplicate_final_answer": true
    },
    "final_format": {
      "tag": "final",
      "must_follow_original_task_formatting": true
    },
    "semantic_generation": {
      "step_segmentation": "heuristic_plus_manual_review",
      "paraphrase_generation": "model_first",
      "distractor_generation": "model_first",
      "rule_generation_allowed": false
    },
    "notes": [
      "The benchmark instance is procedural and frozen.",
      "The reasoning trace is generated by the model under a thin wrapper with assistant prefill to stabilize opening tags.",
      "Semantic interventions are model-generated rather than rule-generated."
    ]
  },
  "slices": {
    "dev": {
      "seed": 1729,
      "high_dependency_prompts": 24,
      "shallow_prompts": 24
    },
    "final": {
      "seed": 314159,
      "high_dependency_prompts": 48,
      "shallow_prompts": 48
    }
  },
  "budgets": {
    "traces_per_prompt": 2,
    "candidate_steps_per_trace_max": 2,
    "paraphrases_per_step": 1,
    "distractors_per_step": 1,
    "continuation_rollouts_per_intervention": 2
  },
  "artifacts": {
    "root": "artifacts/object_gate",
    "samples_dir": "artifacts/object_gate/samples",
    "interventions_dir": "artifacts/object_gate/interventions",
    "rollouts_dir": "artifacts/object_gate/rollouts",
    "analysis_dir": "artifacts/object_gate/analysis"
  },
  "acceptance": {
    "signal_existence_prompt_fraction_min": 0.6,
    "proxy_comparison_required": true,
    "invariance_required": true,
    "gate_go_rule": "Pass at least 2 of 3 primary checks and one pass must be proxy comparison."
  },
  "notes": [
    "This config freezes the minimal pilot protocol, not the final paper evaluation.",
    "Family names remain unfrozen until the primary task source is connected.",
    "No baseline sweep or CPV training is allowed before the Object gate is widened."
  ]
}
