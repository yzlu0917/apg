# Local environments and secrets
.env
.env.*
!.env.example
.venv/
venv/
env/
ENV/

# Python caches and test/tool caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter and editor/OS noise
.ipynb_checkpoints/
.DS_Store
Thumbs.db
*.lnk
*.swp
*.swo
*~

# Experiment data, generated artifacts, and run outputs.
# Keep lightweight documentation and manifest templates that explain how runs
# were produced; ignore raw/generated payloads by default.
**/data/**
!**/data/
!**/data/**/
!**/data/**/README.md
!**/data/manifests/
!**/data/manifests/**/
!**/data/manifests/**/*.yaml
!**/data/manifests/**/*.yml

**/artifacts/**
!**/artifacts/
!**/artifacts/**/
!**/artifacts/**/*.md
!**/artifacts/**/*.txt
**/outputs/

# Large model/checkpoint/feature artifacts
*.safetensors
*.ckpt
*.pt
*.pth
*.bin
*.onnx
*.npz
*.npy
*.pkl
*.pickle
*.parquet
*.arrow
*.sqlite
*.db

# Generated tabular/log streams
*.jsonl
*.csv
*.tsv
*.log
*.zip

# LaTeX/build outputs
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.out
*.run.xml
*.synctex.gz
*.toc
*.pdf

# Local packaging/build outputs
build/
dist/
*.egg-info/
.eggs/
